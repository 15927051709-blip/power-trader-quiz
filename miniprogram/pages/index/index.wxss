.app {
  min-height: 100vh;
  padding: 20rpx 24rpx 160rpx;
}

.topbar {
  padding: 18rpx 0 12rpx;
}

.title {
  font-family: Georgia, "Songti SC", serif;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.2;
}

.subtitle {
  margin-top: 6rpx;
  color: #6f6a60;
  font-size: 24rpx;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin: 12rpx 0 18rpx;
}

.stat {
  min-height: 112rpx;
  padding: 18rpx;
  border: 1rpx solid #d9d1bf;
  border-radius: 14rpx;
  background: rgba(255, 253, 246, .9);
  color: #6f6a60;
  font-size: 24rpx;
}

.stat-value {
  display: block;
  margin-bottom: 8rpx;
  color: #14213d;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1;
}

.panel {
  margin-bottom: 18rpx;
  border: 1rpx solid #d9d1bf;
  border-radius: 14rpx;
  background: #fffdf6;
  box-shadow: 0 18rpx 42rpx rgba(20, 33, 61, .10);
  overflow: hidden;
}

.view-switch,
.segments,
.filter,
.source-filter,
.inline-actions {
  display: grid;
  gap: 10rpx;
}

.view-switch {
  grid-template-columns: repeat(2, 1fr);
  padding: 8rpx;
  background: #ece3cf;
}

.segments {
  grid-template-columns: repeat(5, 1fr);
  padding: 8rpx;
  border: 1rpx solid #d9d1bf;
  border-radius: 14rpx;
  background: #ece3cf;
}

.filter {
  grid-template-columns: repeat(4, 1fr);
}

.source-filter {
  grid-template-columns: repeat(3, 1fr);
}

button {
  min-height: 72rpx;
  border-radius: 12rpx;
  color: #14213d;
  font-size: 26rpx;
  line-height: 72rpx;
}

.active {
  background: #14213d;
  color: #fff;
}

.filter button,
.source-filter button,
.small,
.ghost {
  border: 1rpx solid #d9d1bf;
  background: #fff;
}

.controls {
  padding: 18rpx;
}

.search-row {
  display: grid;
  grid-template-columns: 1fr 120rpx;
  gap: 12rpx;
}

input {
  min-height: 76rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d9d1bf;
  border-radius: 14rpx;
  background: #fff;
  font-size: 28rpx;
}

.primary {
  background: #fca311;
  color: #241706;
  font-weight: 800;
}

.setup-button {
  margin-top: 12rpx;
}

.summary,
.analysis {
  display: block;
  margin-bottom: 12rpx;
  padding: 18rpx;
  border: 1rpx solid #d9d1bf;
  border-radius: 14rpx;
  background: #fff;
  color: #6f6a60;
  font-size: 26rpx;
  line-height: 1.55;
}

.summary-title {
  display: block;
  margin-bottom: 8rpx;
  color: #14213d;
  font-weight: 800;
}

.in-card {
  margin: 0 22rpx 22rpx;
}

.question-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 22rpx;
  border-bottom: 1rpx solid #d9d1bf;
  background: #fff8e6;
}

.question-head.light {
  background: #fffdf6;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  min-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 10rpx;
  background: rgba(42, 157, 143, .12);
  color: #16675e;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 42rpx;
}

.tag.multi { background: rgba(252, 163, 17, .18); color: #8a5600; }
.tag.judge { background: rgba(39, 125, 161, .14); color: #17536c; }
.tag.scope { background: rgba(209, 73, 91, .10); color: #8c2736; }

.progress {
  color: #6f6a60;
  font-size: 24rpx;
}

.compact {
  min-width: 128rpx;
  min-height: 56rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  line-height: 56rpx;
}

.stem {
  padding: 30rpx 22rpx 20rpx;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.55;
}

.options {
  display: grid;
  gap: 16rpx;
  padding: 0 22rpx 22rpx;
}

.option {
  display: grid;
  grid-template-columns: 62rpx 1fr;
  gap: 16rpx;
  align-items: start;
  width: 100%;
  min-height: 92rpx;
  padding: 16rpx;
  border: 1rpx solid #d9d1bf;
  border-radius: 14rpx;
  background: #fff;
  text-align: left;
  line-height: 1.45;
}

.option.selected {
  border-color: #277da1;
  background: rgba(39, 125, 161, .09);
}

.option.correct {
  border-color: #2a9d8f;
  background: rgba(42, 157, 143, .13);
}

.option.wrong {
  border-color: #d1495b;
  background: rgba(209, 73, 91, .10);
}

.letter {
  width: 58rpx;
  height: 58rpx;
  border-radius: 12rpx;
  background: #14213d;
  color: #fff;
  font-weight: 800;
  line-height: 58rpx;
  text-align: center;
}

.option-text {
  padding-top: 6rpx;
  white-space: normal;
}

.feedback {
  margin: 0 22rpx 22rpx;
  padding: 18rpx;
  border: 1rpx solid #d9d1bf;
  border-radius: 14rpx;
  background: #fff8e6;
  line-height: 1.55;
}

.feedback.good {
  border-color: rgba(42, 157, 143, .45);
  background: rgba(42, 157, 143, .10);
}

.feedback.bad {
  border-color: rgba(209, 73, 91, .45);
  background: rgba(209, 73, 91, .10);
}

.answer-sheet {
  display: grid;
  grid-template-columns: repeat(10, 1fr);
  gap: 8rpx;
  padding: 0 22rpx 22rpx;
}

.answer-sheet button {
  min-height: 54rpx;
  border: 1rpx solid #d9d1bf;
  border-radius: 10rpx;
  background: #fff;
  font-size: 22rpx;
  line-height: 54rpx;
}

.answer-sheet .current {
  border-color: #14213d;
  background: #14213d;
  color: #fff;
}

.answer-sheet .answered {
  border-color: rgba(42, 157, 143, .55);
  background: rgba(42, 157, 143, .12);
}

.answer-sheet .marked {
  border-color: rgba(252, 163, 17, .8);
}

.score-box {
  padding: 34rpx 20rpx 22rpx;
  text-align: center;
  color: #6f6a60;
}

.score {
  display: block;
  color: #14213d;
  font-family: Georgia, "Songti SC", serif;
  font-size: 92rpx;
  font-weight: 800;
  line-height: 1;
}

.breakdown {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  padding: 0 22rpx 22rpx;
}

.breakdown view {
  padding: 18rpx 8rpx;
  border: 1rpx solid #d9d1bf;
  border-radius: 14rpx;
  background: #fff8e6;
  text-align: center;
  color: #6f6a60;
}

.break-score {
  display: block;
  color: #14213d;
  font-size: 34rpx;
  font-weight: 800;
}

.inline-actions {
  grid-template-columns: repeat(2, 1fr);
  padding: 0 22rpx 22rpx;
}

.review-list {
  display: grid;
  gap: 14rpx;
  padding: 0 22rpx 22rpx;
}

.review-item {
  display: grid;
  gap: 6rpx;
  padding: 18rpx;
  border: 1rpx solid #d9d1bf;
  border-radius: 14rpx;
  background: #fff;
  line-height: 1.55;
}

.review-title {
  font-weight: 800;
}

.empty {
  padding: 46rpx 28rpx;
  color: #6f6a60;
  line-height: 1.6;
  text-align: center;
}

.actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #d9d1bf;
  background: rgba(248, 244, 232, .96);
}

button[disabled] {
  opacity: .45;
}
