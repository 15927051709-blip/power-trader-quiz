<view class="app">
  <view class="topbar">
    <view>
      <view class="title">电力交易刷题</view>
      <view class="subtitle">{{metaText}}</view>
    </view>
  </view>

  <view class="stats">
    <view class="stat"><text class="stat-value">{{statA}}</text><text>{{statALabel}}</text></view>
    <view class="stat"><text class="stat-value">{{statB}}</text><text>{{statBLabel}}</text></view>
    <view class="stat"><text class="stat-value">{{statC}}</text><text>{{statCLabel}}</text></view>
  </view>

  <view class="panel view-switch">
    <button class="{{view === 'practice' ? 'active' : ''}}" data-view="practice" bindtap="setView">日常刷题</button>
    <button class="{{view === 'exam' ? 'active' : ''}}" data-view="exam" bindtap="setView">模拟考试</button>
  </view>

  <view wx:if="{{view === 'practice'}}" class="panel controls">
    <view class="segments">
      <button wx:for="{{modeOptions}}" wx:key="value" class="{{mode === item.value ? 'active' : ''}}" data-mode="{{item.value}}" bindtap="setMode">{{item.label}}</button>
    </view>

    <view class="filter">
      <button wx:for="{{filterOptions}}" wx:key="value" class="{{filter === item.value ? 'active' : ''}}" data-filter="{{item.value}}" bindtap="setFilter">{{item.label}}</button>
    </view>

    <view class="source-filter">
      <button wx:for="{{sourceOptions}}" wx:key="value" class="{{source === item.value ? 'active' : ''}}" data-source="{{item.value}}" bindtap="setSource">{{item.label}}</button>
    </view>

    <view class="search-row">
      <input value="{{search}}" placeholder="搜索题干关键词" bindinput="onSearchInput" />
      <button class="small" bindtap="resetStats">重置</button>
    </view>
  </view>

  <view wx:if="{{view === 'exam'}}" class="panel controls">
    <view class="summary">
      <text class="summary-title">模拟考试规则</text>
      <text>单选 50 题，多选 15 题，判断 20 题。满分 100 分，限时 120 分钟。</text>
    </view>

    <view class="source-filter">
      <button wx:for="{{sourceOptions}}" wx:key="value" class="{{examSource === item.value ? 'active' : ''}}" data-source="{{item.value}}" bindtap="setExamSource">{{item.label}}</button>
    </view>

    <button class="primary setup-button" bindtap="startExam">开始模拟考试</button>

    <view class="analysis">
      <text class="summary-title">成绩分析</text>
      <text>{{analysisText}}</text>
    </view>

    <view class="analysis">
      <text class="summary-title">最近成绩</text>
      <text>{{historyText}}</text>
    </view>
  </view>

  <view class="panel question">
    <block wx:if="{{view === 'practice'}}">
      <view wx:if="{{practiceEmpty}}" class="empty">{{emptyText}}</view>
      <block wx:else>
        <view class="question-head">
          <view class="tag-row">
            <text class="tag {{currentTypeClass}}">{{currentQuestion.type}}</text>
            <text class="tag scope">{{sourceLabel}}</text>
          </view>
          <button class="small compact" bindtap="toggleFavorite">{{favoriteText}}</button>
        </view>
        <view class="question-head light">
          <text class="progress">{{practiceProgress}}</text>
          <text class="progress">{{weakText}}</text>
        </view>
        <view class="stem">{{currentQuestion.stem}}</view>
        <view class="options">
          <button wx:for="{{currentOptions}}" wx:key="label" class="option {{item.className}}" data-label="{{item.label}}" bindtap="selectOption">
            <text class="letter">{{item.label}}</text>
            <text class="option-text">{{item.text}}</text>
          </button>
        </view>
        <view wx:if="{{feedbackText}}" class="feedback {{feedbackClass}}">{{feedbackText}}</view>
      </block>
    </block>

    <block wx:if="{{view === 'exam'}}">
      <view wx:if="{{examStatus === 'setup'}}">
        <view class="question-head">
          <view class="tag-row">
            <text class="tag scope">{{examSourceLabel}}</text>
            <text class="tag">模拟考试</text>
          </view>
          <text class="progress">满分 100</text>
        </view>
        <view class="stem">准备开始一套完整模拟考试</view>
        <view class="summary in-card">
          <text class="summary-title">单选50题 · 多选15题 · 判断20题</text>
          <text>题型顺序固定为单选、多选、判断。多选全对 2 分，部分正确且无错选 1 分。</text>
        </view>
      </view>

      <view wx:if="{{examStatus === 'active'}}">
        <view class="question-head">
          <view class="tag-row">
            <text class="tag {{currentTypeClass}}">{{examQuestion.type}}</text>
            <text class="tag scope">{{examSourceLabel}}</text>
            <text class="tag">第 {{examDisplayIndex}} / 85 题</text>
          </view>
          <button class="small compact" bindtap="toggleExamMark">{{examMarkText}}</button>
        </view>
        <view class="question-head light">
          <text class="progress">剩余 {{examRemainingText}}</text>
          <text class="progress">{{examQuestionScore}} 分</text>
        </view>
        <view class="stem">{{examQuestion.stem}}</view>
        <view class="options">
          <button wx:for="{{examOptions}}" wx:key="label" class="option {{item.className}}" data-label="{{item.label}}" bindtap="selectOption">
            <text class="letter">{{item.label}}</text>
            <text class="option-text">{{item.text}}</text>
          </button>
        </view>
        <view class="answer-sheet">
          <button wx:for="{{answerSheet}}" wx:key="index" class="{{item.className}}" data-index="{{item.index}}" bindtap="goExamQuestion">{{item.label}}</button>
        </view>
      </view>

      <view wx:if="{{examStatus === 'result'}}">
        <view class="question-head">
          <view class="tag-row">
            <text class="tag scope">{{examSourceLabel}}</text>
            <text class="tag">模拟考试结果</text>
          </view>
          <text class="progress">{{examDurationText}}</text>
        </view>
        <view class="score-box">
          <text class="score">{{examScore}}</text>
          <text>满分 100 · 已答 {{examAnswered}}/85</text>
        </view>
        <view class="breakdown">
          <view wx:for="{{examBreakdown}}" wx:key="type">
            <text class="break-score">{{item.score}}/{{item.max}}</text>
            <text>{{item.type}}</text>
          </view>
        </view>
        <view class="inline-actions">
          <button class="ghost" bindtap="backToPractice">日常刷题</button>
          <button class="primary" bindtap="startExam">再考一套</button>
        </view>
        <view class="review-list">
          <view wx:for="{{reviewItems}}" wx:key="id" class="review-item">
            <text class="review-title">{{item.title}}</text>
            <text>你的答案：{{item.selectedText}}</text>
            <text>正确答案：{{item.answerText}}</text>
            <text>得分：{{item.score}}/{{item.max}} · 已加入错题本</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{showActions}}" class="actions">
    <button class="ghost" disabled="{{leftDisabled}}" bindtap="leftAction">{{leftText}}</button>
    <button class="primary" disabled="{{rightDisabled}}" bindtap="rightAction">{{rightText}}</button>
  </view>
</view>
